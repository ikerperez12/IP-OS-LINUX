# IP Linux does not require any environment variable to run locally.
# All optional cloud features must use PUBLIC keys; never paste a secret key
# here because Vite inlines VITE_* variables into the public bundle.

# Example for an OPTIONAL future Supabase deployment (anon key only).
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
